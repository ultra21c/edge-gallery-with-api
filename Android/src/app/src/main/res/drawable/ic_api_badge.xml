<!--
 Centered "API" badge overlaid on the launcher icon. Centering means the badge sits well
 within every OEM mask's safe zone (the 66dp inner circle), so all three letters render
 without any clipping.

   * Badge center  : (54, 54) — the launcher viewport center
   * Outer radius  : 18  (white ring)
   * Inner radius  : 15  (green fill — Tailwind green-500 / Material Green 500)
   * "API" letters : ~13 tall, total ~24 wide, drawn as filled vector paths.
                     fillType="evenOdd" carves the negative space inside A and P.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- White outer ring -->
  <path
      android:fillColor="#FFFFFFFF"
      android:pathData="M54,54 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0 Z" />

  <!-- Green inner disk -->
  <path
      android:fillColor="#FF22C55E"
      android:pathData="M54,54 m-15,0 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0 Z" />

  <!-- White "A" -->
  <path
      android:fillColor="#FFFFFFFF"
      android:fillType="evenOdd"
      android:pathData="M42.6,60.8 L46.5,47.2 L48.5,47.2 L52.4,60.8 L49.9,60.8 L49.05,57.7 L45.95,57.7 L45.1,60.8 Z M46.55,55.55 L48.45,55.55 L47.5,52.05 Z" />

  <!-- White "P" -->
  <path
      android:fillColor="#FFFFFFFF"
      android:fillType="evenOdd"
      android:pathData="M53.5,47.2 L53.5,60.8 L56,60.8 L56,56.4 L58,56.4 C60.3,56.4 62,54.5 62,51.8 C62,49.1 60.3,47.2 58,47.2 Z M56,49.5 L58,49.5 C59.1,49.5 59.6,50.4 59.6,51.8 C59.6,53.2 59.1,54.1 58,54.1 L56,54.1 Z" />

  <!-- White "I" -->
  <path
      android:fillColor="#FFFFFFFF"
      android:pathData="M63.8,47.2 L63.8,60.8 L66.3,60.8 L66.3,47.2 Z" />
</vector>
